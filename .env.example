BOT_TOKEN=your_telegram_bot_token_here

# Optional: paste cookies.txt content here for Railway-style hosted deploys.
# When unset, the bot reads ./cookies.txt (bind-mounted on docker compose).
# INSTAGRAM_COOKIES_TXT=

# Optional: comma-separated Telegram user IDs that bypass DAILY_QUOTA and
# receive admin-alert DMs (e.g. when Instagram cookies expire).
# ADMIN_USER_IDS=123456789,987654321

# Optional: max requests per user per 24h. 0 disables. Default 200.
# DAILY_QUOTA=200

# Optional: Sentry DSN for error reporting. When unset, Sentry is disabled.
# SENTRY_DSN=

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
# LOG_LEVEL=INFO
